{
  "name": "Movie Crescent - Amon Bot",
  "description": "Movie Crescent links sharing bot (Amon). Share and manage private links with auto approval, admin system, and broadcast features.",
  "keywords": [
    "telegram",
    "bot",
    "links",
    "sharing",
    "pyrogram"
  ],
  "repository": "https://github.com/Sahil0976/Links-Sharing",
  "logo": "https://i.ibb.co/FgPVtzw/logo.png",

  "env": {
    "TG_BOT_TOKEN": {
      "description": "Get bot token from @BotFather",
      "value": ""
    },

    "OWNER_ID": {
      "description": "Your Telegram user ID",
      "value": "8662719308"
    },

    "APP_ID": {
      "description": "Get from https://my.telegram.org",
      "value": ""
    },

    "API_HASH": {
      "description": "Get from https://my.telegram.org",
      "value": ""
    },

    "DATABASE_URL": {
      "description": "MongoDB connection string",
      "value": ""
    },

    "DATABASE_NAME": {
      "description": "Database name",
      "value": "movie_crescent"
    },

    "ADMINS": {
      "description": "Space separated admin user IDs",
      "value": "8662719308",
      "required": false
    },

    "BOT_USERNAME": {
      "description": "Bot username (@LinkShare1_bot)",
      "value": "@LinkShare1_bot"
    },

    "CHANNEL_USERNAME": {
      "description": "Support channel (@MovieCrescent)",
      "value": "@MovieCrescent"
    }
  },

  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ],

  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  }
  }
